  <div class="skills-canvas">
    <!-- Easily add more skills by copying a block and updating top/left percentages -->
    
    <div class="skill-block" style="top: 10%; left: 10%;">
      <h4>01: core languages</h4>
      <p>c++, python, c#, java, c, gdscript</p>
