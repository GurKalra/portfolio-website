<style>
  .footer {
    width: 100%;
    background-color: #FFFFFF;
    padding: 1.5rem calc(4rem + 28px);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .footer-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
  }

  .resume-btn {
    background-color: var(--btn-bg);
    color: #FFFFFF;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  .resume-btn:hover {
    transform: translateY(-2px);
  }

  .footer-center {
    flex: 1;
    display: flex;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .footer-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .social-icon {
    color: var(--text-primary);
    transition: transform 0.2s;
  }

  .social-icon:hover {
    transform: scale(1.1);
  }
</style>
