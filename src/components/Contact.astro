<div class="contact-section">
  <h2 class="contact-heading">contact me</h2>
  
  <div class="contact-container">
    <!-- Web3Forms integration for direct email sending without an email client -->
    <form id="contact-form-element" class="contact-form">
      <!-- Form Access Key from Web3Forms -->
      <input type="hidden" name="access_key" value="cacc7a07-c16e-4ba2-a10b-aef8b7645155">
      
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="Value" required />
      </div>
      
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Value" required />
      </div>
      
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" placeholder="Value" required></textarea>
      </div>
    </form>
    
    <div class="submit-container">
      <button type="button" id="contact-submit-btn" class="submit-btn">Submit</button>
    </div>
  </div>

  <!-- Infinite Scrolling Text -->
  <div class="scrolling-text-container">
    <div class="scroll-wrapper">
      <div class="scrolling-text">
        contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me
      </div>
      <div class="scrolling-text" aria-hidden="true">
        contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me<br>contact me
      </div>
    </div>
  </div>
</div>

<style>
  .contact-section {
    position: relative;
    margin-top: 4rem;
    padding-bottom: 2rem;
    z-index: 1;
    min-height: 500px;
  }

  .contact-heading {
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .contact-container {
    display: flex;
    align-items: center;
    gap: 2rem;
    position: relative;
    z-index: 2; /* Keep above scrolling text */
  }

  .contact-form {
    background-color: var(--btn-bg); /* Dark grey matching screenshot */
    border-radius: 8px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 600px;
    max-width: 100%;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    color: var(--bg-color); /* Beige text on dark bg */
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border-radius: 6px;
    border: none;
    font-family: inherit;
    font-size: 1rem;
    background-color: #FFFFFF;
    color: var(--text-primary);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #A0A0A0;
  }

  .submit-btn {
    background-color: var(--btn-bg);
    color: #FFFFFF;
    border-radius: 8px;
    padding: 2.5rem 1.5rem;
    font-size: 1.1rem;
    cursor: pointer;
    border: none;
    transition: transform 0.2s, background-color 0.2s;
    position: relative;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    background-color: #1a1a1a;
  }

  /* Infinite Scrolling Text */
  .scrolling-text-container {
    position: absolute;
    top: 0;
    right: 2.5rem;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .scroll-wrapper {
    display: flex;
    flex-direction: column;
    animation: scroll-vertical 25s linear infinite;
    will-change: transform;
  }

  .scrolling-text {
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.2;
    color: #1A1A1A;
    text-align: right;
  }

  @keyframes scroll-vertical {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }
  :global(.contact-tooltip) {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background-color: var(--btn-bg);
    color: var(--btn-text);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 200;
  }

  :global(.contact-tooltip.show) {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form-element');
    const button = document.getElementById('contact-submit-btn');

    if (form && button) {
      button.addEventListener('click', async () => {
        // Check form validity first
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const originalText = button.textContent;
        button.textContent = 'Sending...';

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' }
          });

          button.textContent = originalText;

          if (response.ok) {
            form.reset();
            showTooltip('form submitted');
          } else {
            showTooltip('error sending');
          }
        } catch (err) {
          button.textContent = originalText;
          showTooltip('error sending');
        }
      });

      function showTooltip(message) {
        // Remove any existing tooltips
        document.querySelectorAll('.contact-tooltip').forEach(t => t.remove());

        const tooltip = document.createElement('div');
        tooltip.className = 'contact-tooltip';
        tooltip.textContent = message;
        button.appendChild(tooltip);

        requestAnimationFrame(() => tooltip.classList.add('show'));

        setTimeout(() => {
          tooltip.classList.remove('show');
          setTimeout(() => tooltip.remove(), 200);
        }, 2000);
      }
    }
  });
</script>
