    <div class="scroll-wrapper">
      <div class="scrolling-text">
        projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects
