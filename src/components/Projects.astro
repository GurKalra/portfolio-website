<div class="projects-section">
  <h2 class="projects-heading">projects</h2>

  <!-- Background scrolling text -->
  <div class="scrolling-text-container">
    <div class="scroll-wrapper">
      <div class="scrolling-text">
        projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects
      </div>
      <div class="scrolling-text" aria-hidden="true">
        projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects<br>projects
      </div>
    </div>
  </div>

  <div class="project-overlay"></div>

  <div class="projects-grid-container">
    <div class="projects-grid">
      {projects.map((project, i) => (
        <div class="card project-card" data-project-index={i}>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="project-links">
            {project.liveLink ? (
              <a href={project.liveLink} target="_blank" rel="noopener noreferrer">
                <Fragment set:html={linkSvg} />
              </a>
            ) : (
              <span class="link-icon" data-message={project.liveMessage}>
                <Fragment set:html={linkSvg} />
              </span>
            )}
            <a href={project.githubLink} target="_blank" rel="noopener noreferrer">
              <Fragment set:html={githubSvg} />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ projects, linkSvg, githubSvg }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Tooltip handling
    document.addEventListener('click', (e) => {
      const linkIcon = e.target.closest('.link-icon[data-message]');
      if (linkIcon) {
        e.stopPropagation();
        document.querySelectorAll('.link-tooltip').forEach(t => t.remove());
        const tooltip = document.createElement('div');
        tooltip.className = 'link-tooltip';
        tooltip.textContent = linkIcon.dataset.message;
        linkIcon.appendChild(tooltip);
        requestAnimationFrame(() => tooltip.classList.add('show'));
        setTimeout(() => {
          tooltip.classList.remove('show');
          setTimeout(() => tooltip.remove(), 200);
        }, 2000);
        return;
      }
    });

    const cards = document.querySelectorAll('.project-card');
    const overlay = document.querySelector('.project-overlay');
    let expandedPanel = null;
    let activeOriginalCard = null;

    function buildScrollerText(name) {
      return Array(50).fill(name).join(' · ');
    }

    function buildExpandedPanel(project) {
      const panel = document.createElement('div');
      panel.className = 'expanded-panel';

      const scrollerText = buildScrollerText(project.title);

      const skillsHtml = project.skills
        .map((s, i) => `${String(i + 1).padStart(2, '0')}: ${s}`)
        .join('<br>');

      let linksHtml = '';
      if (project.liveLink) {
        linksHtml += `<a href="${project.liveLink}" target="_blank" rel="noopener noreferrer">${linkSvg}</a>`;
      } else {
        linksHtml += `<span class="link-icon" data-message="${project.liveMessage}">${linkSvg}</span>`;
      }
      linksHtml += `<a href="${project.githubLink}" target="_blank" rel="noopener noreferrer">${githubSvg}</a>`;

      panel.innerHTML = `
        <div class="expanded-content">
          <div class="expanded-left">
            <h3>${project.title}</h3>
            <p>${project.description}</p>
            <div class="expanded-skills">${skillsHtml}</div>
            <div class="expanded-links">${linksHtml}</div>
          </div>
          <div class="expanded-scroller">
            <div class="expanded-scroller-track">
              <div class="expanded-scroller-text">${scrollerText}</div>
              <div class="expanded-scroller-text" aria-hidden="true">${scrollerText}</div>
            </div>
          </div>
          <div class="expanded-right">
            <h4>the what?</h4>
            <p>${project.what}</p>
            <h4>the why?</h4>
            <p>${project.why}</p>
          </div>
        </div>
      `;

      return panel;
    }

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('.project-links')) return;
        if (expandedPanel) return;

        activeOriginalCard = card;
        const cardRect = card.getBoundingClientRect();
        const idx = parseInt(card.dataset.projectIndex);
        const project = projects[idx];

        expandedPanel = buildExpandedPanel(project);

        // 1. Measure natural height using an invisible clone at target width
        const targetWidth = Math.min(window.innerWidth - 120, 1100);
        const measureClone = expandedPanel.cloneNode(true);
        measureClone.style.position = 'fixed';
        measureClone.style.visibility = 'hidden';
        measureClone.style.width = targetWidth + 'px';
        measureClone.style.height = 'auto';
        measureClone.style.left = '-9999px';
        measureClone.style.top = '0';
        document.body.appendChild(measureClone);
        const naturalHeight = Math.min(measureClone.offsetHeight, window.innerHeight - 60);
        measureClone.remove();

        // 2. Place panel at the clicked card's exact position (no transition yet)
        expandedPanel.style.position = 'fixed';
        expandedPanel.style.left = cardRect.left + 'px';
        expandedPanel.style.top = cardRect.top + 'px';
        expandedPanel.style.width = cardRect.width + 'px';
        expandedPanel.style.height = cardRect.height + 'px';
        expandedPanel.style.opacity = '0';
        document.body.appendChild(expandedPanel);

        // Force reflow so browser registers the starting position
        expandedPanel.offsetHeight;

        // 3. Add transition class and animate to centered position
        const targetLeft = (window.innerWidth - targetWidth) / 2;
        const targetTop = (window.innerHeight - naturalHeight) / 2;

        expandedPanel.classList.add('animating');
        requestAnimationFrame(() => {
          expandedPanel.style.width = targetWidth + 'px';
          expandedPanel.style.height = naturalHeight + 'px';
          expandedPanel.style.left = targetLeft + 'px';
          expandedPanel.style.top = targetTop + 'px';
          expandedPanel.style.opacity = '1';
        });

        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    // Close
    overlay.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePanel();
    });

    function closePanel() {
      if (!expandedPanel || !activeOriginalCard) return;

      const rect = activeOriginalCard.getBoundingClientRect();
      expandedPanel.style.width = rect.width + 'px';
      expandedPanel.style.height = rect.height + 'px';
      expandedPanel.style.left = rect.left + 'px';
      expandedPanel.style.top = rect.top + 'px';
      expandedPanel.style.opacity = '0';

      overlay.classList.remove('active');
      document.body.style.overflow = '';

      const panelRef = expandedPanel;
      expandedPanel = null;
      activeOriginalCard = null;

      setTimeout(() => {
        panelRef.remove();
      }, 400);
    }
  });
</script>

<style>
  /* ── Overlay ── */
