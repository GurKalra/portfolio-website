  <div class="projects-grid-container">
    <div class="projects-grid">
      <!-- Project Cards -->
      <div class="card project-card">
        <h3>prescient</h3>
        <p>a proactive, root-level linux system guardian. it hooks directly into native package managers to predict, prevent, and recover from system-breaking os updates before execution.</p>
        <div class="project-skills">
          01: linux system architecture<br>02: python & pytest<br>03: btrfs & timeshift<br>04: bash & posix scripts<br>05: multi-threaded tui
        </div>
        <div class="project-links">
          <span class="link-icon" data-message="this one's only github!">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </span>
