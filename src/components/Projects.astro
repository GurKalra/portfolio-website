<style>
  :global(.project-overlay) {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--bg-color);
    opacity: 0;
    z-index: 100;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  :global(.project-overlay.active) {
    opacity: 0.85;
    pointer-events: auto;
  }

  :global(.card.project-card.active) {
    position: fixed;
    z-index: 101;
    cursor: default;
    background-color: #FFFFFF; /* Hardcode to guarantee style */
    border-radius: 12px;
    padding: 2rem;
    box-sizing: border-box;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    transition: top 0.3s ease, left 0.3s ease, width 0.3s ease, box-shadow 0.3s ease;
    overflow: visible;
  }

  :global(.card.project-card.expanded .project-skills) {
    display: block !important;
    opacity: 1 !important;
  }

  :global(.card.project-card.expanded .project-links) {
    margin-top: 2rem !important;
  }

  :global(.card.project-card.expanded .project-links svg) {
    width: 32px !important;
    height: 32px !important;
  }

  .projects-section {
    position: relative;
    margin-top: 2rem;
    z-index: 1; /* Creates stacking context for the section */
  }

  .projects-heading {
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .projects-grid-container {
    position: relative;
    z-index: 2; /* Explicitly place above scrolling text */
    max-height: 550px;
    overflow-y: auto;
    padding-bottom: 2rem;
    padding-right: 2rem; /* Give room for scrolling text */
    scrollbar-width: none;
    -ms-overflow-style: none;
    mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
  }
  
  .projects-grid-container::-webkit-scrollbar {
    display: none;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    cursor: pointer; /* Indicate it's clickable */
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .project-skills {
    display: none;
    opacity: 0;
    margin-top: 1.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.5;
    color: var(--text-primary);
    transition: opacity 0.3s ease;
  }

  .project-links {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    transition: margin-top 0.3s ease;
  }

  .project-links svg {
    cursor: pointer;
    transition: transform 0.2s, width 0.3s, height 0.3s;
  }

  .project-links svg:hover {
    transform: scale(1.1);
  }

  .project-links a {
    color: inherit;
    display: flex;
    align-items: center;
  }

  .link-icon {
    display: flex;
    align-items: center;
    position: relative;
  }

  :global(.link-tooltip) {
    position: absolute;
    bottom: -2rem;
    right: 0;
    background-color: var(--btn-bg);
    color: var(--btn-text);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 200;
  }

  :global(.link-tooltip.show) {
    opacity: 1;
    transform: translateY(0);
  }

  /* Infinite Scrolling Text */
  .scrolling-text-container {
    position: absolute;
    top: 0;
    right: 2.5rem; /* Sits behind the cards on the right */
    height: 100%;
    overflow: hidden;
    z-index: 0; /* Placed behind the grid which is z-index: 2 */
  }

  .scroll-wrapper {
    display: flex;
    flex-direction: column;
    animation: scroll-vertical 25s linear infinite;
    will-change: transform;
  }

  .scrolling-text {
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.2;
    color: #1A1A1A;
    text-align: right;
  }

  @keyframes scroll-vertical {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%); /* Because there are two identical blocks stacked */
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Handle link-icon tooltip messages
    document.addEventListener('click', (e) => {
      const linkIcon = e.target.closest('.link-icon[data-message]');
      if (linkIcon) {
        e.stopPropagation();
        // Remove any existing tooltips
        document.querySelectorAll('.link-tooltip').forEach(t => t.remove());

        const tooltip = document.createElement('div');
        tooltip.className = 'link-tooltip';
        tooltip.textContent = linkIcon.dataset.message;
        
        // Append to the link-icon itself (already has position:relative)
        linkIcon.appendChild(tooltip);

        // Trigger animation
        requestAnimationFrame(() => tooltip.classList.add('show'));

        // Auto-remove after 2s
        setTimeout(() => {
          tooltip.classList.remove('show');
          setTimeout(() => tooltip.remove(), 200);
        }, 2000);
        return;
      }
    });

    const cards = document.querySelectorAll('.project-card');
    const overlay = document.querySelector('.project-overlay');
    let activeClone = null;
    let activeOriginalCard = null;

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('.project-links')) return;
        if (activeClone) return; // Prevent multiple clicks
        
        activeOriginalCard = card;
        const rect = card.getBoundingClientRect();
        activeClone = card.cloneNode(true);
        
        // Setup initial position to match the card exactly
        activeClone.style.top = `${rect.top}px`;
        activeClone.style.left = `${rect.left}px`;
        activeClone.style.width = `${rect.width}px`;
        activeClone.style.height = `${rect.height}px`;
        activeClone.style.margin = '0';
        activeClone.classList.add('active');
        
        // Add to DOM
        document.body.appendChild(activeClone);
        
        // Force reflow
        activeClone.offsetHeight;
        
        // Calculate target expanded properties
        const expandedWidth = Math.min(600, window.innerWidth - 40);
        let targetLeft = rect.left;
        
        // Ensure the expanded card doesn't overflow the right edge of the viewport
        if (targetLeft + expandedWidth > window.innerWidth - 20) {
          targetLeft = window.innerWidth - expandedWidth - 20;
        }
        if (targetLeft < 20) targetLeft = 20;

        // Animate to expanded state
        activeClone.classList.add('expanded');
        activeClone.style.width = `${expandedWidth}px`;
        activeClone.style.height = 'auto';
        activeClone.style.minHeight = '400px';
        activeClone.style.left = `${targetLeft}px`;
        
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    overlay.addEventListener('click', () => {
      if (activeClone && activeOriginalCard) {
        // Animate back to the exact original card that was clicked
        const originalRect = activeOriginalCard.getBoundingClientRect();
        
        activeClone.classList.remove('expanded');
        activeClone.style.width = `${originalRect.width}px`;
        activeClone.style.height = `${originalRect.height}px`;
        activeClone.style.minHeight = '';
        activeClone.style.top = `${originalRect.top}px`;
        activeClone.style.left = `${originalRect.left}px`;

        overlay.classList.remove('active');
        document.body.style.overflow = '';

        // Wait for transition to finish before removing
        setTimeout(() => {
          if (activeClone) {
            activeClone.remove();
            activeClone = null;
            activeOriginalCard = null;
          }
        }, 300);
      }
    });
  });
</script>
